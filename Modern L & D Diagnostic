.stage-insight{margin-top:20px;border-radius:12px;overflow:hidden;border:1px solid #D4EFE0;}
.si-header{padding:18px 22px 14px;border-bottom:1px solid #D4EFE0;}
.si-label{font-size:9px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#4A8C3F;margin-bottom:6px;}
.si-title{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:#1E4A1A;margin-bottom:8px;}
.si-def{font-size:13px;color:#3A4A38;line-height:1.85;font-weight:300;}
.si-body{padding:18px 22px;display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.si-col-label{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:10px;}
.si-col-label.pros{color:#3A7A34;}
.si-col-label.cons{color:#B85C38;}
.si-item{font-size:12px;color:#3A4A38;line-height:1.7;font-weight:300;padding:8px 10px 8px 12px;border-radius:6px;margin-bottom:6px;}
.si-item.pro{background:#F2FAF5;border-left:3px solid #3A7A34;}
.si-item.con{background:#FDF5F2;border-left:3px solid #B85C38;}
.si-relevance{background:#F2F8F0;border-top:1px solid #D4EFE0;padding:16px 22px;}
.si-rel-label{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#4A8C3F;margin-bottom:6px;}
.si-rel-text{font-size:12px;color:#3A4A38;line-height:1.8;font-weight:300;}
.wl-wrap{background:#1E4A1A;border-radius:14px;padding:28px;margin-top:20px;}
.wl-label{font-size:9px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#8FD5A6;margin-bottom:8px;}
.wl-title{font-family:'Playfair Display',serif;font-size:22px;color:white;font-weight:700;margin-bottom:8px;}
.wl-sub{font-size:13px;color:rgba(255,255,255,.65);line-height:1.8;font-weight:300;margin-bottom:20px;}
.wl-form{display:flex;flex-direction:column;gap:10px;max-width:440px;}
.wl-input{padding:12px 16px;border:1.5px solid rgba(143,213,166,.25);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;color:white;background:rgba(255,255,255,.06);outline:none;}
.wl-btn{background:#FFE600;color:#1E4A1A;padding:14px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:700;cursor:pointer;border:none;}
.wl-confirm{background:rgba(143,213,166,.1);border:1px solid rgba(143,213,166,.25);border-radius:8px;padding:16px 20px;text-align:center;display:none;}
.wl-confirm-text{font-size:13px;color:#8FD5A6;line-height:1.7;}
.copyright{font-size:10px;color:#A0B09E;text-align:center;margin-top:24px;line-height:1.6;}
@media(max-width:480px){.arch-grid{grid-template-columns:1fr;}.course-card{flex-direction:column;}.si-body{grid-template-columns:1fr;}}
</style>
</head>
<body>
<div class="wrap">

<!-- INTRO -->
<div id="intro">
  <div style="background:#1E4A1A;border-radius:16px;padding:40px 36px 36px;margin-bottom:20px;">
    <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(143,213,166,.1);border:1px solid rgba(143,213,166,.2);border-radius:20px;padding:5px 14px;margin-bottom:16px;">
      <span style="width:6px;height:6px;border-radius:50%;background:#8FD5A6;display:inline-block;"></span>
