.btn-ghost:hover{border-color:#4A8C3F;color:#1E4A1A;}
/* PROGRESS */
.prog-wrap{margin-bottom:26px;}
.prog-info{display:flex;justify-content:space-between;font-size:11px;color:#8FAD8E;margin-bottom:7px;}
