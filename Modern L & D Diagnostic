.sec-num{width:36px;height:36px;border-radius:50%;background:rgba(143,213,166,.12);border:1.5px solid rgba(143,213,166,.25);display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:16px;font-weight:700;color:#8FD5A6;flex-shrink:0;}
.sec-tag{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(143,213,166,.5);margin-bottom:3px;}
.sec-name{font-family:'Playfair Display',serif;font-size:17px;color:white;font-weight:700;}
/* QUESTION */
.q-card{background:white;border:1px solid #D4EFE0;border-radius:10px;padding:22px 24px;margin-bottom:12px;}
.q-num{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#4A8C3F;margin-bottom:8px;}
.q-text{font-size:14px;color:#1E2E1C;line-height:1.7;margin-bottom:18px;font-weight:500;}
.mc-options{display:flex;flex-direction:column;gap:9px;}
.mc-btn{width:100%;text-align:left;padding:13px 16px;border:1.5px solid #D4EFE0;border-radius:8px;background:white;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:13px;color:#3A4A38;line-height:1.6;transition:all .15s;font-weight:300;}
.mc-btn:hover{border-color:#4A8C3F;background:#F5FBF5;}
.mc-btn.sel{color:white;}
.mc-btn.sel[data-v="1"]{background:#B85C38;border-color:#B85C38;}
.mc-btn.sel[data-v="2"]{background:#C87840;border-color:#C87840;}
.mc-btn.sel[data-v="3"]{background:#9A8020;border-color:#9A8020;}
.mc-btn.sel[data-v="4"]{background:#3A7A34;border-color:#3A7A34;}
.mc-btn.sel[data-v="5"]{background:#1E4A1A;border-color:#1E4A1A;}
.nav-row{display:flex;justify-content:space-between;align-items:center;margin-top:22px;}
.q-ctr{font-size:12px;color:#8FAD8E;}
