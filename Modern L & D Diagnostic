.gate-form{display:flex;flex-direction:column;gap:10px;max-width:420px;margin:0 auto;}
.gate-input{padding:13px 16px;border:1.5px solid #D4EFE0;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;color:#1E4A1A;background:#FAFDF8;outline:none;}
.gate-input:focus{border-color:#4A8C3F;}
.gate-btn{background:#1E4A1A;color:white;padding:14px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:700;cursor:pointer;border:none;margin-top:4px;}
.gate-privacy{font-size:10px;color:#A0B09E;margin-top:8px;}
