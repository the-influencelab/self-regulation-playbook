    tagline:'"I stopped waiting for the profession to change. I became the change."',
    color:"#1E4A1A",
    p1:"You do not need this diagnostic to tell you who you are. You already know.",
    p2:"What you might not fully see yet is the impact you are having on the people around you — the way your presence in a room shifts what is possible, the way your willingness to say the difficult thing gives others permission to say theirs, the way your credibility has been built so quietly and so consistently that it now precedes you.",
    p3:"The Quiet Disruptor does not announce themselves. They do not need to. They change cultures by modelling something different — a standard of presence, courage and professional integrity that others find themselves trying to match without quite knowing why. They are not the loudest voice. They are the most trusted one.",
    pull:"Full Drive is not a destination. It is a daily practice — and the professionals who stay here are the ones who know that. Who keep doing the inner work. Who resist the temptation to coast on hard-won credibility and instead use their position to actively raise the standard of everyone around them.",
    keeping:"Isolation. Or worse — comfort. The greatest threat to a Full Drive professional is the quiet, seductive belief that they have arrived. You have not arrived. You have earned the right to go further.",
    need:"Your voice. Your standards. Your willingness to be the person who tells the truth about what L&D is and what it needs to become — loudly enough that the people still in Drift can hear it.",
    courses:[
      {icon:"📖",title:"Modern L&D: From Drift to Drive",desc:"The final chapter is yours. It asks the question that Full Drive professionals most need to sit with: who am I bringing with me, and how?",tag:"book"},
      {icon:"🎓",title:"The Influence Lab Masterclass",desc:"For Full Drive professionals ready to lead change at organisational and sector level. This is where your practice becomes a platform for others.",tag:"course"},
      {icon:"👥",title:"One-to-One Strategic Coaching with Kay",desc:"For the professional who has earned the right to think at the highest level about their impact, their legacy and their next chapter.",tag:"coaching"}
    ]
  }
};

const tagLabels={book:"📚 The Book",course:"🎓 Course",coaching:"👥 Coaching"};

let cur=0,ans=Array(30).fill(0),savedStage=null;

function start(){
  document.getElementById('intro').style.display='none';
  document.getElementById('diag').style.display='block';
  render(0);
}

function render(si){
  var s=S[si];
  var html='';
  html+='<div class="sec-header">';
  html+='<div class="sec-num">'+s.num+'</div>';
  html+='<div><div class="sec-tag">'+s.tag+'</div>';
  html+='<div class="sec-name">'+s.name+'</div></div></div>';
  for(var qi=0;qi<s.qs.length;qi++){
    var q=s.qs[qi];
    var ai=si*6+qi;
    html+='<div class="q-card">';
    html+='<div class="q-num">Question '+(ai+1)+' of 30</div>';
    html+='<div class="q-text">'+q.q+'</div>';
    html+='<div class="mc-options">';
    for(var oi=0;oi<q.o.length;oi++){
      var v=oi+1;
      var sel=(ans[ai]===v)?' sel':'';
      html+='<button class="mc-btn'+sel+'" data-ai="'+ai+'" data-v="'+v+'">'+q.o[oi]+'</button>';
    }
    html+='</div></div>';
  }
  document.getElementById('sc').innerHTML=html;
  var btns=document.getElementById('sc').querySelectorAll('.mc-btn');
  for(var i=0;i<btns.length;i++){
    btns[i].addEventListener('click',function(){
      var ai=parseInt(this.getAttribute('data-ai'));
      var v=parseInt(this.getAttribute('data-v'));
      pick(ai,v,this);
    });
  }
  nav(si);
}

function pick(ai,v,btn){
  ans[ai]=v;
  var opts=btn.parentNode;
  var all=opts.querySelectorAll('.mc-btn');
  for(var i=0;i<all.length;i++){
    all[i].classList.remove('sel');
    all[i].style.background='';
    all[i].style.borderColor='';
    all[i].style.color='';
  }
  btn.classList.add('sel');
  nav(cur);
}

function nav(si){
  const f=ans.slice(si*6,si*6+6).filter(v=>v>0).length;
  const t=ans.filter(v=>v>0).length;
  document.getElementById('bn').disabled=f<6;
  document.getElementById('bb').style.visibility=si>0?'visible':'hidden';
  document.getElementById('pt').textContent=`Section ${si+1} of 5`;
  document.getElementById('qp').textContent=`${t} of 30 answered`;
  document.getElementById('pf').style.width=(t/30*100)+'%';
  document.getElementById('qc').textContent=`${f}/6 in this section`;
  document.getElementById('bn').textContent=si===4?'See My Results →':'Next Section →';
}

function next(){if(cur<4){cur++;render(cur);window.scrollTo(0,0);}else showGate();}
function back(){if(cur>0){cur--;render(cur);window.scrollTo(0,0);}}

function showGate(){
  const total=ans.reduce((a,b)=>a+b,0);
  const pct=Math.round((total/150)*100);
  savedStage=stages.find(s=>pct>=s.min&&pct<=s.max)||stages[4];
  document.getElementById('diag').style.display='none';
  document.getElementById('gate').style.display='block';
  window.scrollTo(0,0);
}

function unlockResults(){
  const name=document.getElementById('g-name').value.trim();
  const email=document.getElementById('g-email').value.trim();
  const org=document.getElementById('g-org').value.trim();
  if(!name||!email||!org){
    alert('Please fill in all three fields to unlock your profile.');
    return;
  }
  // Pre-fill waiting list form
  document.getElementById('wl-name').value=name;
  document.getElementById('wl-email').value=email;
  document.getElementById('wl-org').value=org;

  document.getElementById('gate').style.display='none';
  buildResults(savedStage);
  document.getElementById('results').style.display='block';
  window.scrollTo(0,0);
}

function buildResults(stage){
  const total=ans.reduce((a,b)=>a+b,0);
  const pct=Math.round((total/150)*100);

  document.getElementById('rs').textContent=stage.name;
  document.getElementById('rsc').textContent=pct;
  document.getElementById('rp').textContent=stage.profile;
  setTimeout(()=>{document.getElementById('spp').style.left=Math.min(pct,96)+'%';},300);

  const bsc=S.map((_,i)=>Math.round((ans.slice(i*6,i*6+6).reduce((a,b)=>a+b,0)/30)*100));
  document.getElementById('bdr').innerHTML=S.map((s,i)=>{
    const sc=bsc[i],ni=sc>=80?0:sc>=60?1:sc>=45?2:sc>=30?3:4;
    const col=sc>=80?'#1E4A1A':sc>=60?'#3A7A34':sc>=45?'#9A8020':sc>=30?'#C87840':'#B85C38';
    return `<div class="b-row"><div class="b-top"><span class="b-name">${s.name}</span><span class="b-score" style="color:${col}">${sc}<span style="font-size:11px;color:#8FAD8E;">/100</span></span></div><div class="b-bar"><div class="b-fill" style="width:${sc}%;background:${col};"></div></div><div class="b-note">${bn[i][ni]}</div></div>`;
  }).join('');

  // Archetype panel
  const arch=archetypes[stage.name];
  if(arch){
    document.getElementById('archetype-panel').innerHTML=`
      <div class="arch-hero" style="background:${arch.color};">
        <div class="arch-eyebrow">The Drift-to-Drive Diagnostic™ · Your Full Profile</div>
        <div class="arch-type">${arch.type}</div>
        <div class="arch-name">${arch.name}</div>
        <div class="arch-tagline">${arch.tagline}</div>
      </div>
      <div class="arch-body">
        <div class="arch-section-label">Your Profile</div>
        <div class="arch-para">${arch.p1}</div>
        <div class="arch-para">${arch.p2}</div>
        <div class="arch-para">${arch.p3}</div>
        <div class="arch-pull">${arch.pull}</div>
        <div class="arch-grid">
          <div class="arch-card keeping">
            <div class="arch-card-label">What is keeping you here</div>
            <div class="arch-card-text">${arch.keeping}</div>
          </div>
          <div class="arch-card need">
            <div class="arch-card-label">What your organisation needs from you</div>
            <div class="arch-card-text">${arch.need}</div>
          </div>
        </div>
      </div>`;

    // Course panel
    document.getElementById('course-panel').innerHTML=arch.courses.map(c=>`
      <div class="course-card">
        <div class="course-icon">${c.icon}</div>
        <div>
          <div class="course-title">${c.title}</div>
          <div class="course-desc">${c.desc}</div>
          <span class="course-tag ${c.tag}">${tagLabels[c.tag]}</span>
        </div>
      </div>`).join('');
  }

  // Stage insight panel
  const ins=stageInsights[stage.name];
  if(ins){
    document.getElementById('stage-insight').innerHTML=`
      <div class="stage-insight" style="margin-top:16px;">
        <div class="si-header">
          <div class="si-label">Understanding Your Stage</div>
          <div class="si-title">${stage.name} — What This Stage Really Means</div>
          <div class="si-def">${ins.def}</div>
        </div>
        <div class="si-body">
          <div class="si-col">
            <div class="si-col-label pros">What works at this stage</div>
            ${ins.pros.map(p=>`<div class="si-item pro">${p}</div>`).join('')}
          </div>
          <div class="si-col">
            <div class="si-col-label cons">What holds you back</div>
            ${ins.cons.map(c=>`<div class="si-item con">${c}</div>`).join('')}
          </div>
        </div>
        <div class="si-relevance">
          <div class="si-rel-label">Why This Matters in Modern L&D</div>
          <div class="si-rel-text">${ins.relevance}</div>
        </div>
      </div>`;
  }

  document.getElementById('rrt').textContent=stage.rt;
  document.getElementById('rrq').innerHTML=stage.rq.map(q=>`<div class="ref-q">${q}</div>`).join('');
}

function joinWaitlist(){
  const name=document.getElementById('wl-name').value.trim();
  const email=document.getElementById('wl-email').value.trim();
  const org=document.getElementById('wl-org').value.trim();
  if(!name||!email){alert('Please enter your name and email to join the waiting list.');return;}
  // CONNECT TO FORMSPREE/MAILCHIMP HERE WHEN READY
  document.getElementById('wl-form').style.display='none';
  document.getElementById('wl-confirm').style.display='block';
}

function retake(){
  ans=Array(20).fill(0);cur=0;savedStage=null;
  document.getElementById('results').style.display='none';
  document.getElementById('gate').style.display='none';
  document.getElementById('intro').style.display='block';
  window.scrollTo(0,0);
}

</script>
</body>
</html>
