.course-tag{font-size:10px;font-weight:700;padding:3px 10px;border-radius:12px;}
.course-tag.book{background:#FEF3E8;color:#8B4A10;}
.course-tag.course{background:#E8F5EE;color:#1E6B38;}
.course-tag.coaching{background:#EEF2FF;color:#3A40A0;}
.ref-box{background:#F2F8F0;border-left:4px solid #4A8C3F;border-radius:0 8px 8px 0;padding:22px 24px;margin-top:20px;}
.ref-lbl{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#4A8C3F;margin-bottom:6px;}
.ref-title{font-family:'Playfair Display',serif;font-size:17px;color:#1E4A1A;margin-bottom:12px;}
.ref-q{font-size:13px;color:#3A4A38;line-height:1.8;margin-bottom:8px;padding-left:16px;position:relative;font-weight:300;}
