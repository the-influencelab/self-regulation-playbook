<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:#FAFDF8;color:#1A1A1A;min-height:100vh;}
.wrap{max-width:760px;margin:0 auto;padding:40px 24px;}
.hidden{display:none!important;}
.btn-primary{background:#1E4A1A;color:white;padding:14px 32px;border-radius:6px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer;border:none;transition:all .2s;margin-top:16px;}
