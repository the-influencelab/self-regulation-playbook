.gate-wrap{background:white;border:1px solid #D4EFE0;border-radius:14px;padding:32px;margin-bottom:20px;text-align:center;}
.gate-title{font-family:'Playfair Display',serif;font-size:22px;font-weight:900;color:#1E4A1A;margin-bottom:8px;}
