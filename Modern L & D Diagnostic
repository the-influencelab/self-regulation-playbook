.arch-para{font-size:13px;color:#2A3A28;line-height:1.9;font-weight:300;margin-bottom:12px;}
.arch-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px;}
.arch-card{border-radius:8px;padding:16px;}
